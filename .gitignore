# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Node / Next.js
web/node_modules/
web/.next/
web/out/
web/data/
web/.env*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Local config
*.db
*.sqlite

# Runtime logs
*.log
desktop/_app_run.log

# PyInstaller build output
desktop/build/
desktop/dist/

# Bundled/added audio (keep the folder + README, ignore large tracks)
desktop/assets/music/*
!desktop/assets/music/README.txt
web/public/audio/*.mp3
web/public/audio/*.m4a
web/public/audio/*.ogg
!web/public/audio/README.md
!web/public/audio/manifest.json

# Baked originals for the ping-pong script (not served)
public/scenes/_original/

# Chrome extension signing key + built store zips (never commit)
extension/store/*.pem
extension/store/*.zip
