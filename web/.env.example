# Fellowship Focus — web env

# Auth.js / NextAuth (required for Google Sign-In)
AUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_URL=https://fellowship-focus-production.up.railway.app

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — Gemini coach (/api/ai/coach). Heuristic fallback if unset.
GEMINI_API_KEY=

# DATA_DIR=/data
