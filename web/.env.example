# Fellowship Focus — web env
# Copy to .env.local (do not commit secrets). See docs/GOOGLE-OAUTH-SETUP.md

# Auth.js / NextAuth (required in production)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# Production example:
# AUTH_URL=https://fellowship-focus-production.up.railway.app

# Google OAuth (Sign in) — preferred names; AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET also work
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Focus tab — coding activity, private events when connected)
# Create at https://github.com/settings/developers → OAuth Apps
# Callback URL: {AUTH_URL}/api/auth/callback/github
# Full guide: docs/GITHUB-OAUTH-SETUP.md
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional server PAT for higher public API rate limits
# GITHUB_TOKEN=

# Optional — Gemini coach (/api/ai/coach) + asset scripts (generate-*.mjs).
# Heuristic coach fallback if unset. Guild card art: npm run generate-guild-illustrations
GEMINI_API_KEY=

# DATA_DIR=/data

# ── Escrow.com (goal bets / weekly stakes) ─────────────
# Auth = HTTP Basic (email:api_key). Production by default.
# ESCROW_EMAIL=
# ESCROW_API_KEY=
# ESCROW_SANDBOX=1
# Shared secret YOU invent; webhook URL = /api/escrow/webhook?key=<this>
# ESCROW_WEBHOOK_KEY=
# Optional: same key or dedicated secret for Sunday auto-settle cron
# CRON_SECRET=