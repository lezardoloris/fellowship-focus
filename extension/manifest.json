{
  "manifest_version": 3,
  "name": "Fellowship Focus — Blocker",
  "version": "1.5.0",
  "description": "Block distracting sites, schedules, friction mode, history suggestions, sync with Fellowship Focus.",
  "key": "",
  "permissions": ["declarativeNetRequest", "storage", "alarms", "notifications", "tabs", "browsingData", "webNavigation"],
  "optional_permissions": ["history"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://fellowship-focus-production.up.railway.app/*",
        "https://*.up.railway.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fellowship Focus",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://fellowship-focus-production.up.railway.app/*",
      "https://*.up.railway.app/*",
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://localhost/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["block.html", "friction.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
